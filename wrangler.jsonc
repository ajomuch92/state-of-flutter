{
	"compatibility_date": "2026-03-22",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "state-of-flutter",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
		"binding": "SESSION",
		"id": "0a518c45425f476b8ad58450d052789a"
		}
	]
}