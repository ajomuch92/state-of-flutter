---
import Layout from "../layouts/Layout.astro";

const topics = [
  "State Management",
  "Navigation & Routing",
  "Favorite Packages",
  "Backend & APIs",
  "Testing Practices",
  "CI/CD Pipelines",
  "Target Platforms",
  "Dart Language Use",
  "Team Size & Structure",
  "Flutter Version Adoption",
  "Design Systems",
  "Monetization Models",
  "AI & LLM Integration",
  "Developer Experience",
  "Community & Learning",
];
---

<Layout
  title="State of Flutter 2026"
  bodyClass="bg-flutter-bg text-slate-200 font-syne overflow-x-hidden relative"
>
  <div
    class="fixed -top-37.5 -left-25 w-150 h-150 rounded-full bg-flutter-teal opacity-[.17] blur-[120px] pointer-events-none z-0 animate-drift1"
  >
  </div>
  <div
    class="fixed -bottom-25 -right-20 w-120 h-120 rounded-full bg-blue-700 opacity-[.17] blur-[120px] pointer-events-none z-0 animate-drift2"
  >
  </div>
  <div
    class="fixed top-[40%] left-[55%] w-75 h-75 rounded-full bg-flutter-accent opacity-[.08] blur-[120px] pointer-events-none z-0 animate-drift3"
  >
  </div>

  <!-- ── NAV ── -->
  <nav
    class="relative z-10 border-b border-flutter-blue/10 backdrop-blur-md bg-flutter-bg/75"
  >
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <div
        class="flex items-center gap-2 font-mono text-[.82rem] tracking-widest text-flutter-blue uppercase"
      >
        <span
          class="w-2 h-2 rounded-full bg-flutter-accent animate-pulse2 inline-block"
        ></span>
        State of Flutter
      </div>
      <div
        class="flex items-center gap-6 font-mono text-[.75rem] tracking-widest text-slate-500"
      >
        <a href="#about" class="hover:text-flutter-blue transition-colors"
          >About</a
        >
        <a href="#topics" class="hover:text-flutter-blue transition-colors"
          >Topics</a
        >
      </div>
    </div>
  </nav>

  <main class="relative z-1">
    <div class="max-w-4xl mx-auto px-6">
      <!-- ── HERO ── -->
      <section class="pt-24 pb-16 text-center">
        <!-- Badge -->
        <div
          class="animate-fadeUp inline-flex items-center gap-2 font-mono text-[.7rem] tracking-[.14em] uppercase text-flutter-teal border border-flutter-teal/30 bg-flutter-teal/[.07] px-4 py-1.5 rounded-full mb-8"
        >
          <span
            class="w-1.5 h-1.5 rounded-full bg-flutter-accent animate-pulse2 inline-block"
          ></span>
          Survey · Now Open · 2026
        </div>

        <!-- Headline -->
        <h1
          class="animate-fadeUp2 font-syne font-extrabold leading-[1.05] tracking-tight"
        >
          <span
            class="block font-mono font-normal text-flutter-accent text-[clamp(1.1rem,3vw,1.7rem)] tracking-[.18em] mb-2"
          >
            State of
          </span>
          <span class="gradient-text text-[clamp(3rem,8vw,5.8rem)]"
            >Flutter</span
          >
        </h1>

        <!-- Sub -->
        <p
          class="animate-fadeUp3 mt-6 text-slate-400 text-lg leading-relaxed max-w-xl mx-auto"
        >
          We're crafting the most comprehensive developer survey on Flutter ever
          made. Help us map the ecosystem, uncover 2026 trends, and shape the
          future of cross-platform development.
        </p>

        <!-- CTA -->
        <div class="animate-fadeUp4 mt-10 flex flex-col items-center gap-3">
          <a
            href="#"
            class="cta-btn inline-flex items-center gap-2.5 font-mono font-bold text-[.9rem] tracking-widest text-flutter-bg px-8 py-3.5 rounded-full"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M9 11l3 3L22 4"></path><path
                d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
              ></path>
            </svg>
            Take the Survey
          </a>
          <span class="font-mono text-[.7rem] tracking-wider text-slate-500"
            >~8 minutes · Anonymous · Open until April 30</span
          >
        </div>
      </section>

      <hr class="h-divider my-2" />

      <!-- ── STATS ── -->
      <div
        class="my-12 flex flex-wrap justify-center gap-12 border border-flutter-blue/10 rounded-2xl bg-flutter-card/60 backdrop-blur-md px-8 py-8"
      >
        <div class="text-center">
          <strong
            class="block font-mono text-[2rem] text-flutter-blue leading-none"
            >2026</strong
          >
          <span
            class="font-mono text-[.68rem] tracking-widest text-slate-500 uppercase mt-1.5 block"
            >Edition</span
          >
        </div>
        <div class="text-center">
          <strong
            class="block font-mono text-[2rem] text-flutter-blue leading-none"
            >~8 min</strong
          >
          <span
            class="font-mono text-[.68rem] tracking-widest text-slate-500 uppercase mt-1.5 block"
            >To complete</span
          >
        </div>
        <div class="text-center">
          <strong
            class="block font-mono text-[2rem] text-flutter-blue leading-none"
            >100%</strong
          >
          <span
            class="font-mono text-[.68rem] tracking-widest text-slate-500 uppercase mt-1.5 block"
            >Anonymous</span
          >
        </div>
        <div class="text-center">
          <strong
            class="block font-mono text-[2rem] text-flutter-blue leading-none"
            >Global</strong
          >
          <span
            class="font-mono text-[.68rem] tracking-widest text-slate-500 uppercase mt-1.5 block"
            >Developer reach</span
          >
        </div>
      </div>

      <!-- ── ABOUT ── -->
      <section id="about" class="mt-6">
        <p
          class="font-mono text-[.7rem] tracking-[.16em] uppercase text-flutter-teal mb-2"
        >
          Why it matters
        </p>
        <h2
          class="font-syne font-extrabold text-white text-[clamp(1.5rem,4vw,2.3rem)] mb-6 leading-tight"
        >
          Built by the community,<br />for the community
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <article
            class="feature-card relative border border-flutter-blue/10 rounded-xl bg-flutter-card p-6 overflow-hidden transition-all duration-200 hover:border-flutter-blue/35 hover:-translate-y-0.5"
          >
            <span class="text-[1.6rem] mb-3 block">📊</span>
            <h3
              class="font-syne font-bold text-flutter-blue text-[1rem] mb-1.5"
            >
              Understand real trends
            </h3>
            <p class="text-slate-400 text-[.87rem] leading-relaxed">
              From state management choices to favorite packages — we want to
              know what Flutter developers are actually using in production in
              2026.
            </p>
          </article>

          <article
            class="feature-card relative border border-flutter-blue/10 rounded-xl bg-flutter-card p-6 overflow-hidden transition-all duration-200 hover:border-flutter-blue/35 hover:-translate-y-0.5"
          >
            <span class="text-[1.6rem] mb-3 block">🌍</span>
            <h3
              class="font-syne font-bold text-flutter-blue text-[1rem] mb-1.5"
            >
              Global developer pulse
            </h3>
            <p class="text-slate-400 text-[.87rem] leading-relaxed">
              The survey is open to Flutter developers everywhere. The more
              responses, the more representative and powerful the data becomes.
            </p>
          </article>

          <article
            class="feature-card relative border border-flutter-blue/10 rounded-xl bg-flutter-card p-6 overflow-hidden transition-all duration-200 hover:border-flutter-blue/35 hover:-translate-y-0.5"
          >
            <span class="text-[1.6rem] mb-3 block">🔓</span>
            <h3
              class="font-syne font-bold text-flutter-blue text-[1rem] mb-1.5"
            >
              Fully open results
            </h3>
            <p class="text-slate-400 text-[.87rem] leading-relaxed">
              All findings will be published publicly. No paywalls, no
              gatekeeping — raw numbers and insights available to everyone.
            </p>
          </article>

          <article
            class="feature-card relative border border-flutter-blue/10 rounded-xl bg-flutter-card p-6 overflow-hidden transition-all duration-200 hover:border-flutter-blue/35 hover:-translate-y-0.5"
          >
            <span class="text-[1.6rem] mb-3 block">🚀</span>
            <h3
              class="font-syne font-bold text-flutter-blue text-[1rem] mb-1.5"
            >
              Shape what's next
            </h3>
            <p class="text-slate-400 text-[.87rem] leading-relaxed">
              Your answers inform the ecosystem — tooling authors, companies
              hiring Flutter devs, and the Flutter team itself pay attention to
              surveys like this.
            </p>
          </article>
        </div>
      </section>

      <!-- ── TOPICS ── -->
      <section id="topics" class="mt-16">
        <p
          class="font-mono text-[.7rem] tracking-[.16em] uppercase text-flutter-teal mb-2"
        >
          What we'll cover
        </p>
        <h2
          class="font-syne font-extrabold text-white text-[clamp(1.5rem,4vw,2.3rem)] mb-6 leading-tight"
        >
          Survey topics
        </h2>

        <ul class="flex flex-wrap gap-2.5 list-none p-0 m-0">
          {
            topics.map((t) => (
              <li class="font-mono text-[.76rem] tracking-wider px-4 py-1.5 border border-flutter-blue/20 rounded-full text-slate-200 bg-flutter-blue/4 cursor-default transition-all duration-150 hover:border-flutter-teal hover:text-flutter-teal hover:bg-flutter-teal/10">
                {t}
              </li>
            ))
          }
        </ul>
      </section>

      <hr class="h-divider my-14" />

      <!-- ── BOTTOM CTA ── -->
      <section class="text-center pb-20">
        <p
          class="font-mono text-[.7rem] tracking-[.16em] uppercase text-flutter-teal mb-2"
        >
          Ready?
        </p>
        <h2
          class="font-syne font-extrabold text-white text-[clamp(1.5rem,4vw,2.3rem)] mb-4 leading-tight"
        >
          Your voice matters.
        </h2>
        <p
          class="text-slate-400 text-[.95rem] leading-relaxed max-w-md mx-auto mb-8"
        >
          It only takes 8 minutes. No account needed. Help us paint the most
          accurate picture of Flutter development in 2026.
        </p>
        <a
          href="#"
          class="cta-btn inline-flex items-center gap-2.5 font-mono font-bold text-[.9rem] tracking-widest text-flutter-bg px-8 py-3.5 rounded-full"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M9 11l3 3L22 4"></path><path
              d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
            ></path>
          </svg>
          Take the Survey
        </a>
      </section>
    </div>
  </main>

  <!-- ── FOOTER ── -->
  <footer class="relative z-10 border-t border-flutter-blue/8 py-6 text-center">
    <p class="font-mono text-[.7rem] tracking-wider text-slate-500">
      State of Flutter 2026 · Community-driven · Results published openly ·
      <a href="#" class="text-flutter-blue hover:underline">Share the survey</a>
    </p>
  </footer>
</Layout>
