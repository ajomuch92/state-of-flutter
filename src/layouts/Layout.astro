---
import "../styles/global.css";

interface Props {
  title?: string;
  bodyClass?: string;
}

const { title, bodyClass } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>
      {title ? `${title} · State of Flutter` : "State of Flutter"}
    </title>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta
      name="description"
      content="The community-driven survey to understand how Flutter developers around the world are building in 2026. Open, free, and fully public results."
    />
    <meta
      name="keywords"
      content="Flutter, Dart, Flutter survey, State of Flutter, Flutter 2026, Flutter developers, cross-platform, mobile development"
    />
    <meta name="author" content="ajomuch92" />
    <link rel="canonical" href="https://stateofflutter.com" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(84, 197, 248, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(84, 197, 248, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  /* Gradient text */
  .gradient-text {
    background: linear-gradient(135deg, #ffffff 0%, #54c5f8 55%, #01baef 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Card top-border reveal */
  .feature-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #01baef, #54c5f8);
    opacity: 0;
    transition: opacity 0.25s;
  }
  .feature-card:hover::before {
    opacity: 1;
  }

  /* CTA glow */
  .cta-btn {
    background: linear-gradient(135deg, #01baef, #54c5f8);
    box-shadow: 0 0 32px rgba(1, 186, 239, 0.38);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }
  .cta-btn:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 0 56px rgba(1, 186, 239, 0.6);
  }

  /* Horizontal divider */
  .h-divider {
    border: none;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(84, 197, 248, 0.25),
      transparent
    );
  }
</style>
